          {
            "title": "(2) 第二次热平衡",
            "content": "$$100c(60-t)=C(t-20)=\\frac{500c}{3}(t-20)$$"
          },
          {
            "title": "(3) 解出温度",
            "content": "$$300(60-t)=500(t-20)$$\n\n$$t=35°C$$"
          }
        ],
        "finalAnswer": "③ $35°C$",
        "correctOption": "③"
      }
    },
    {
