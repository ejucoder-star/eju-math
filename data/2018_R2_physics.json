      "topicTag": "热力学·热量守恒",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "$20°C$ 的金属容器中放入 $60°C$ 的水 $5.0\\times10^2\\,\\mathrm{g}$，平衡后容器和水均为 $50°C$。若把水量改为 $1.0\\times10^2\\,\\mathrm{g}$，仍放入 $20°C$ 的同一金属容器，平衡后温度为 $t$，求 $t$。",
      "options": [
        {
          "label": "①",
          "content": "25"
        },
        {
          "label": "②",
          "content": "30"
        },
        {
          "label": "③",
          "content": "35"
