    {
      "id": "2018-r2-phys-11",
      "number": "III-B 问2",
      "topic": "运动声源和运动观察者的多普勒效应",
      "topicTag": "波动·多普勒效应",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "声源以速度 $v_S$ 向前运动并发出振动数 $f_0$ 的声音，观察者以速度 $v_O$ 同向运动。观察者在声源前方时观测频率为 $f_1$，在声源后方时观测频率为 $f_2$。声速为 $V$，求 $f_2/f_1$。",
      "options": [
        {
          "label": "①",
          "content": "$\\dfrac{(V-v_S)(V+v_O)}{(V+v_S)(V-v_O)}$"
        },
        {
          "label": "②",
          "content": "$\\dfrac{(V+v_S)(V-v_O)}{(V-v_S)(V+v_O)}$"
        },
        {
          "label": "③",
          "content": "$\\dfrac{(V-v_S)(V-v_O)}{(V+v_S)(V+v_O)}$"
        },
        {
          "label": "④",
          "content": "$\\dfrac{(V+v_S)(V+v_O)}{(V-v_S)(V-v_O)}$"
        }
      ],
      "questionImage": "/images/2018_R2_physics/q11.png",
      "solution": {
        "translation": "分别写出观察者在声源前方和后方时的多普勒频率。",
        "analysis": "前方时声源向观察者接近，而观察者远离声源；后方时声源远离观察者，而观察者向波源方向接近后方传播的波。",
        "steps": [
          {
            "title": "写出频率",
            "content": "$$f_1=f_0\\frac{V-v_O}{V-v_S}$$\n\n$$f_2=f_0\\frac{V+v_O}{V+v_S}$$"
          },
          {
            "title": "求比值",
            "content": "$$\\frac{f_2}{f_1}=\\frac{(V-v_S)(V+v_O)}{(V+v_S)(V-v_O)}$$"
