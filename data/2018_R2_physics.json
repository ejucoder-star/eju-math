    {
      "id": "2018-r2-phys-1",
      "number": "I-A 问1",
      "topic": "受绳约束的水平杆静力平衡",
      "topicTag": "力学·力矩平衡",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "长为 $4\\ell$ 的均匀细棒 AB，一端 A 接长 $3\\ell$ 的竖直绳 a，另一端 B 接长 $5\\ell$ 的绳 b，悬挂于相距 $8\\ell$ 的天花板两点。A 还被水平绳 c 向左拉，棒水平静止。设绳 c 拉力为 $F$，棒重为 $W$，求 $F$。",
      "options": [
        {
          "label": "①",
          "content": "$\\dfrac{3}{10}W$"
        },
        {
          "label": "②",
          "content": "$\\dfrac{3}{8}W$"
        },
        {
          "label": "③",
          "content": "$\\dfrac{2}{5}W$"
        },
        {
          "label": "④",
          "content": "$\\dfrac{5}{8}W$"
        },
        {
          "label": "⑤",
          "content": "$\\dfrac{2}{3}W$"
        },
        {
          "label": "⑥",
          "content": "$\\dfrac{5}{6}W$"
        }
      ],
      "questionImage": "/images/2018_R2_physics/q01.png",
      "solution": {
        "translation": "先由几何确定 B 端绳 b 的方向，再对 A 点取力矩求绳 b 张力，最后用水平方向平衡求 $F$。",
        "analysis": "B 端到悬点的水平、竖直距离构成 $4\\ell-3\\ell-5\\ell$ 三角形，因此绳 b 的水平分量为 $4T/5$，竖直分量为 $3T/5$。",
        "steps": [
          {
            "title": "(1) 对 A 点取力矩",
            "content": "$$\\frac{3}{5}T\\cdot4\\ell=W\\cdot2\\ell$$\n\n$$T=\\frac{5}{6}W$$"
          },
          {
            "title": "(2) 水平方向平衡",
            "content": "$$F=\\frac{4}{5}T=\\frac{4}{5}\\cdot\\frac{5}{6}W=\\frac{2}{3}W$$"
          }
        ],
        "finalAnswer": "⑤ $\\dfrac{2}{3}W$",
        "correctOption": "⑤"
      }
    },
