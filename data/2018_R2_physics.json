    {
      "id": "2018-r2-phys-3",
      "number": "I-C 问3",
      "topic": "光滑曲面后的水平抛出",
      "topicTag": "力学·能量与抛体运动",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "光滑曲面 AB 的上端 A 离地高度为 $H$，下端 B 离地高度为 $h$。小物体从 A 静止释放，从 B 水平飞出后落到地面 C，且 B 到 C 的水平距离为 $2h$。求 $H/h$。",
      "options": [
        {
          "label": "①",
          "content": "$\\dfrac54$"
        },
        {
          "label": "②",
          "content": "$\\dfrac32$"
        },
        {
          "label": "③",
          "content": "$\\dfrac74$"
        },
        {
          "label": "④",
          "content": "2"
        },
        {
          "label": "⑤",
          "content": "$\\dfrac94$"
        },
        {
          "label": "⑥",
          "content": "$\\dfrac52$"
        }
      ],
      "questionImage": "/images/2018_R2_physics/q03.png",
      "solution": {
        "translation": "由水平抛出运动求 B 点速度，再用机械能守恒连接 A、B 的高度差。",
        "analysis": "从 B 到地面下落高度为 $h$，水平位移为 $2h$。",
        "steps": [
          {
            "title": "(1) 抛体运动求速度",
            "content": "$$h=\\frac12gt^2,\\qquad 2h=v_Bt$$\n\n$$v_B^2=2gh$$"
          },
          {
            "title": "(2) 能量守恒",
            "content": "$$mg(H-h)=\\frac12mv_B^2=mgh$$\n\n$$H=2h$$"
          }
        ],
        "finalAnswer": "④ $\\dfrac{H}{h}=2$",
        "correctOption": "④"
      }
    },
    {
      "id": "2018-r2-phys-4",
      "number": "I-D 问4",
      "topic": "碰撞中的力积矢量关系",
      "topicTag": "力学·冲量动量",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "质量 $m$ 的小物体 A 以速度 $\\vec v_1$ 撞击物体 B，碰后 A 的速度变为 $\\vec v_2$。碰撞中 B 受到的力积为 $\\vec F\\Delta t$。判断 $m\\vec v_1$、$m\\vec v_2$ 与 $\\vec F\\Delta t$ 的关系图。",
      "options": [
        {
          "label": "①",
          "content": "图①"
        },
        {
          "label": "②",
          "content": "图②"
        },
        {
          "label": "③",
          "content": "图③"
        },
        {
          "label": "④",
          "content": "图④"
        }
      ],
      "questionImage": "/images/2018_R2_physics/q04.png",
      "solution": {
        "translation": "A 的动量变化等于 A 受到的力积；B 受到的力积与 A 受到的力积大小相等、方向相反。",
        "analysis": "A 的动量变化为 $m\\vec v_2-m\\vec v_1$，所以 B 得到的力积为 $m\\vec v_1-m\\vec v_2$。",
        "steps": [
          {
            "title": "写出矢量式",
            "content": "$$\\vec F\\Delta t=m\\vec v_1-m\\vec v_2$$\n\n即：$$m\\vec v_2+\\vec F\\Delta t=m\\vec v_1$$"
          }
        ],
        "finalAnswer": "② 图②",
        "correctOption": "②"
      }
    },
    {
      "id": "2018-r2-phys-5",
      "number": "I-E 问5",
      "topic": "圆锥摆角速度",
      "topicTag": "力学·圆周运动",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "长为 $\\ell$ 的轻绳一端固定，另一端接质量 $m$ 的小球。小球在水平面内作等速圆周运动，绳的张力为 $2mg$。求圆运动角速度 $\\omega$。",
      "options": [
        {
          "label": "①",
          "content": "$\\sqrt{\\dfrac{g}{\\ell}}$"
        },
        {
          "label": "②",
          "content": "$\\sqrt{\\dfrac{2g}{\\ell}}$"
        },
        {
          "label": "③",
          "content": "$\\sqrt{\\dfrac{3g}{\\ell}}$"
        },
        {
          "label": "④",
          "content": "$2\\sqrt{\\dfrac{g}{\\ell}}$"
        },
        {
          "label": "⑤",
          "content": "$\\sqrt{\\dfrac{5g}{\\ell}}$"
        },
        {
          "label": "⑥",
          "content": "$\\sqrt{\\dfrac{6g}{\\ell}}$"
        }
      ],
      "questionImage": "/images/2018_R2_physics/q05.png",
      "solution": {
        "translation": "竖直方向张力分量平衡重力，水平方向张力分量提供向心力。",
        "analysis": "设绳与竖直方向夹角为 $\\theta$。由 $T=2mg$ 和 $T\\cos\\theta=mg$ 得 $\\cos\\theta=1/2$。",
        "steps": [
          {
            "title": "列向心条件",
            "content": "$$T\\sin\\theta=m(\\ell\\sin\\theta)\\omega^2$$\n\n$$T=m\\ell\\omega^2$$"
          },
          {
            "title": "代入张力",
            "content": "$$2mg=m\\ell\\omega^2$$\n\n$$\\omega=\\sqrt{\\frac{2g}{\\ell}}$$"
          }
        ],
        "finalAnswer": "② $\\sqrt{\\dfrac{2g}{\\ell}}$",
        "correctOption": "②"
      }
    },
