      "id": "physics-2017-r2-01",
      "number": "I-1",
      "topic": "三力のつり合い",
      "topicTag": "力のつり合い",
      "questionType": "single_choice",
      "questionImage": "/images/2017_R2_physics/q01.png",
      "japanese": "3本の軽い糸a,b,cで質量mの小球をつるす。糸aは鉛直方向となす角60°, 糸bは30°。aの張力Taを求める。",
      "options": [
        "① 1/2 mg",
        "② √3/3 mg",
        "③ √3/2 mg",
        "④ mg",
        "⑤ √3mg"
      ],
      "solution": {
        "translation": "三根轻绳悬挂小球，求左侧绳a的张力。",
        "analysis": "小球静止，水平方向和竖直方向的合力都为0。",
        "steps": [
          {
            "title": "水平方向",
            "content": "水平方向平衡：Ta sin60° = Tb sin30°，所以 Tb = √3 Ta。"
          },
          {
            "title": "竖直方向",
            "content": "竖直方向平衡：Ta cos60° + Tb cos30° = mg。代入 Tb = √3 Ta，得 (1/2)Ta + (3/2)Ta = mg，所以 Ta = mg/2。"
          }
        ],
        "finalAnswer": "①",
        "correctOption": "①"
      },
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false
    },
    {
      "id": "physics-2017-r2-02",
      "number": "I-2",
      "topic": "斜面上の静止摩擦",
      "topicTag": "摩擦力",
      "questionType": "single_choice",
      "questionImage": "/images/2017_R2_physics/q02.png",
      "japanese": "粗い斜面上の物体に斜面上向きの力Fを加える。Fを小さくし，F0より小さくなると物体が滑り始めた。F0を求める。",
      "options": [
        "① mg(cosθ - μsinθ)",
        "② mg(sinθ - μcosθ)",
        "③ mg(1/μ cosθ - sinθ)",
        "④ mg(1/μ sinθ - cosθ)"
      ],
      "solution": {
        "translation": "减小沿斜面向上的外力，刚要向下滑动时求临界力。",
        "analysis": "临界下滑时静摩擦力达到最大值，并沿斜面向上。",
        "steps": [
          {
            "title": "沿斜面平衡",
            "content": "刚要下滑时，沿斜面向下为 mg sinθ，向上为 F0 + μmg cosθ。平衡条件 mg sinθ = F0 + μmg cosθ。"
          },
          {
            "title": "求F0",
            "content": "F0 = mg(sinθ - μcosθ)。"
          }
        ],
        "finalAnswer": "②",
        "correctOption": "②"
      },
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false
    },
    {
      "id": "physics-2017-r2-03",
      "number": "I-3",
      "topic": "アトウッドの装置",
      "topicTag": "運動方程式",
      "questionType": "single_choice",
      "questionImage": "/images/2017_R2_physics/q03.png",
      "japanese": "質量mのAと質量2mのBを軽い糸でつなぎ定滑車にかける。Bを床から高さhで放すと床直前の速さがv。hを求める。",
      "options": [
        "① v^2/(3g)",
        "② v^2/(2g)",
        "③ 2v^2/(3g)",
        "④ v^2/g",
        "⑤ 3v^2/(2g)",
        "⑥ 2v^2/g",
        "⑦ 3v^2/g"
      ],
      "solution": {
        "translation": "阿特伍德装置中，重物B下落h后速度为v，求h。",
        "analysis": "两物体共同加速度为 (2m-m)/(3m)g = g/3。",
        "steps": [
          {
            "title": "加速度",
            "content": "对整体，外力差为 mg，总质量为3m，所以 a = g/3。"
          },
          {
            "title": "运动学",
            "content": "从静止下落 h，有 v^2 = 2ah = 2(g/3)h，故 h = 3v^2/(2g)。"
          }
        ],
        "finalAnswer": "⑤",
        "correctOption": "⑤"
      },
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false
    },
    {
      "id": "physics-2017-r2-04",
      "number": "I-4",
      "topic": "爆発と運動量保存",
      "topicTag": "運動量",
      "questionType": "single_choice",
      "questionImage": "/images/2017_R2_physics/q04.png",
      "japanese": "静止物体が反対方向に運動する2物体A,Bに分裂した。vA/vB と KA/KB の組合せを求める。",
      "options": [
        "① vA/vB=mA/mB, KA/KB=mA/mB",
        "② vA/vB=mA/mB, KA/KB=mB/mA",
        "③ vA/vB=mB/mA, KA/KB=mA/mB",
        "④ vA/vB=mB/mA, KA/KB=mB/mA"
      ],
      "solution": {
        "translation": "静止物体爆炸成反向运动两部分，求速度比和动能比。",
        "analysis": "总动量为0，因此两部分动量大小相等。",
        "steps": [
          {
            "title": "速度比",
            "content": "mA vA = mB vB，所以 vA/vB = mB/mA。"
          },
          {
            "title": "动能比",
            "content": "KA/KB = (mA vA^2)/(mB vB^2) = (mA/mB)(mB/mA)^2 = mB/mA。"
          }
        ],
        "finalAnswer": "④",
        "correctOption": "④"
      },
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false
    },
    {
