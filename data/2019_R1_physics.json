  "questions": [
    {
      "id": "2019-r1-phys-1",
      "number": "I-A 问1",
      "topic": "两根直角轻杆的静力平衡",
      "topicTag": "力学·重心与力矩平衡",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "质量可忽略的两根均匀细杆以直角连接，长度分别为 $\\ell_1,\\ell_2$。两杆端点分别连接质量 $m_1,m_2$ 的小球，在连接点用线悬挂后静止。长度 $\\ell_1$ 的杆与竖直下方成角 $\\theta$，求 $\\tan\\theta$。",
      "options": [
        {
          "label": "①",
          "content": "$\\dfrac{m_1\\ell_1}{m_2\\ell_2}$"
        },
        {
          "label": "②",
          "content": "$\\dfrac{m_2\\ell_2}{m_1\\ell_1}$"
        },
        {
          "label": "③",
          "content": "$\\dfrac{m_2\\ell_1}{m_1\\ell_2}$"
        },
        {
          "label": "④",
          "content": "$\\dfrac{m_1\\ell_2}{m_2\\ell_1}$"
        }
      ],
      "questionImage": "/images/2019_R1_physics/q01.png",
      "solution": {
        "translation": "悬挂静止时，悬点下方必须通过整个系统的重心。也可以说，以悬点为转轴，两个小球重力的力矩平衡。",
        "analysis": "设 $\\ell_1$ 杆与竖直夹角为 $\\theta$，另一根杆与竖直方向的水平投影关系由直角决定。两球到悬点的水平距离分别为 $\\ell_1\\sin\\theta$ 和 $\\ell_2\\cos\\theta$。",
        "steps": [
          {
            "title": "(1) 力矩平衡",
            "content": "$$m_1g\\ell_1\\sin\\theta=m_2g\\ell_2\\cos\\theta$$"
          },
          {
            "title": "(2) 求比值",
            "content": "$$\\tan\\theta=\\frac{m_2\\ell_2}{m_1\\ell_1}$$"
          }
        ],
        "finalAnswer": "② $\\dfrac{m_2\\ell_2}{m_1\\ell_1}$",
        "correctOption": "②"
      }
    },
    {
      "id": "2019-r1-phys-2",
      "number": "I-B 问2",
      "topic": "斜向下抛体运动",
      "topicTag": "力学·抛体运动",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "从距水平地面高 $h$ 的位置，以与水平方向向下成 $45°$ 的方向、初速 $v_0$ 投出小球。小球落地点与投出点的水平距离为 $h/2$，求 $v_0$。",
      "options": [
        {
          "label": "①",
          "content": "$\\dfrac{\\sqrt{gh}}{2}$"
        },
        {
          "label": "②",
          "content": "$\\dfrac{\\sqrt{2gh}}{2}$"
        },
        {
          "label": "③",
          "content": "$\\sqrt{gh}$"
        },
        {
          "label": "④",
          "content": "$\\sqrt{2gh}$"
        },
        {
          "label": "⑤",
          "content": "$2\\sqrt{gh}$"
        }
      ],
      "questionImage": "/images/2019_R1_physics/q02.png",
      "solution": {
        "translation": "把运动分解为水平方向的匀速运动和竖直方向的匀加速运动。",
        "analysis": "水平方向位移为 $h/2$，竖直方向下降 $h$。初速度的水平、竖直向下分量都为 $v_0/\\sqrt2$。",
        "steps": [
          {
            "title": "(1) 水平方向",
            "content": "$$\\frac{v_0}{\\sqrt2}t=\\frac{h}{2}$$\n\n$$t=\\frac{h}{\\sqrt2 v_0}$$"
          },
          {
            "title": "(2) 竖直方向",
            "content": "$$h=\\frac{v_0}{\\sqrt2}t+\\frac12gt^2$$"
          },
          {
            "title": "(3) 代入求解",
            "content": "$$h=\\frac{h}{2}+\\frac12g\\frac{h^2}{2v_0^2}$$\n\n$$v_0=\\frac{\\sqrt{2gh}}{2}$$"
          }
        ],
        "finalAnswer": "② $\\dfrac{\\sqrt{2gh}}{2}$",
        "correctOption": "②"
      }
    },
    {
      "id": "2019-r1-phys-3",
      "number": "I-C 问3",
      "topic": "粗糙斜面上下滑的加速度",
      "topicTag": "力学·摩擦力",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "倾角为 $\\theta$ 的粗糙斜面上，小物体由静止开始下滑时加速度大小为 $a$。同一斜面上给小物体沿斜面向上的初速时，小物体向上滑动时的加速度大小为 $a'$，求 $a'$。",
      "options": [
        {
          "label": "①",
          "content": "$2g\\sin\\theta+a$"
        },
        {
          "label": "②",
          "content": "$2g\\cos\\theta+a$"
        },
        {
          "label": "③",
          "content": "$2g\\tan\\theta+a$"
        },
        {
          "label": "④",
          "content": "$2g\\sin\\theta-a$"
        },
        {
          "label": "⑤",
          "content": "$2g\\cos\\theta-a$"
        },
        {
          "label": "⑥",
          "content": "$2g\\tan\\theta-a$"
        }
      ],
      "questionImage": "/images/2019_R1_physics/q03.png",
      "solution": {
        "translation": "下滑和上滑时，重力沿斜面分力方向相同，但摩擦力方向相反。",
        "analysis": "下滑时 $a=g\\sin\\theta-\\mu g\\cos\\theta$；上滑时速度向上，重力分力和摩擦力都沿斜面向下，所以 $a'=g\\sin\\theta+\\mu g\\cos\\theta$。",
        "steps": [
          {
            "title": "(1) 下滑加速度",
            "content": "$$a=g\\sin\\theta-\\mu g\\cos\\theta$$"
          },
          {
            "title": "(2) 上滑减速度",
            "content": "$$a'=g\\sin\\theta+\\mu g\\cos\\theta$$"
          },
          {
            "title": "(3) 消去摩擦项",
            "content": "$$a'=2g\\sin\\theta-a$$"
          }
        ],
        "finalAnswer": "④ $2g\\sin\\theta-a$",
        "correctOption": "④"
      }
    },
    {
      "id": "2019-r1-phys-4",
      "number": "I-D 问4",
      "topic": "摆球碰撞后的摩擦停止距离",
      "topicTag": "力学·碰撞与能量",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "长为 $\\ell$ 的轻绳一端固定在 O，另一端连接质量 $M$ 的小物体 P。P 从与 O 同高的 A 点静止释放，在最低点 B 与静止的质量 $m$ 的物体 Q 非弹性碰撞。碰后 P 上升到离地高度 $\\ell/4$ 的 C 点，Q 在粗糙水平面滑行距离 $d$ 后停止，动摩擦系数为 $\\mu'$，求 $d$。",
      "options": [
        {
          "label": "①",
          "content": "$\\dfrac{M^2\\ell}{4\\mu'm^2}$"
        },
        {
          "label": "②",
          "content": "$\\dfrac{M^2\\ell}{2\\mu'm^2}$"
        },
        {
          "label": "③",
          "content": "$\\dfrac{3M^2\\ell}{2\\mu'm^2}$"
        },
        {
          "label": "④",
          "content": "$\\dfrac{9M^2\\ell}{4\\mu'm^2}$"
        }
      ],
      "questionImage": "/images/2019_R1_physics/q04.png",
      "solution": {
        "translation": "用能量守恒求碰撞前后 P 的速度，再用碰撞瞬间水平方向动量守恒求 Q 的速度。最后用摩擦做功求停止距离。",
        "analysis": "P 从 A 到 B 下降高度 $\\ell$，碰前速度平方为 $2g\\ell$。碰后 P 只能上升到 $\\ell/4$，所以碰后速度平方为 $g\\ell/2$。",
        "steps": [
          {
            "title": "(1) P 碰前速度",
            "content": "$$\\frac12Mv^2=Mg\\ell$$\n\n$$v=\\sqrt{2g\\ell}$$"
          },
          {
            "title": "(2) P 碰后速度",
            "content": "$$\\frac12Mv_P^2=Mg\\frac{\\ell}{4}$$\n\n$$v_P=\\sqrt{\\frac{g\\ell}{2}}=\\frac{v}{2}$$"
          },
          {
            "title": "(3) 动量守恒",
            "content": "$$Mv=Mv_P+mu$$\n\n$$u=\\frac{M}{m}\\frac{v}{2}$$"
          },
          {
            "title": "(4) 摩擦做功",
            "content": "$$\\mu'mgd=\\frac12mu^2$$\n\n$$d=\\frac{M^2\\ell}{4\\mu'm^2}$$"
          }
        ],
        "finalAnswer": "① $\\dfrac{M^2\\ell}{4\\mu'm^2}$",
        "correctOption": "①"
      }
    },
    {
      "id": "2019-r1-phys-5",
      "number": "I-E 问5",
      "topic": "弹簧振子与单摆周期比较",
      "topicTag": "力学·简谐运动",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "竖直弹簧振子中，小球在平衡位置时弹簧从自然长伸长 $d$，周期为 $T$。同一小球接在长为 $\\ell$ 的轻绳上作小振幅单摆，周期也为 $T$。求 $\\ell/d$。",
      "options": [
        {
          "label": "①",
          "content": "$\\dfrac14$"
        },
        {
          "label": "②",
          "content": "$\\dfrac12$"
        },
        {
          "label": "③",
          "content": "$\\dfrac{\\sqrt2}{2}$"
        },
        {
          "label": "④",
          "content": "1"
        },
        {
          "label": "⑤",
          "content": "$\\sqrt2$"
        },
        {
          "label": "⑥",
          "content": "2"
        },
        {
          "label": "⑦",
          "content": "4"
        }
      ],
      "solution": {
        "translation": "弹簧平衡伸长给出 $k$ 与 $d$ 的关系，再比较弹簧振子和单摆的周期公式。",
        "analysis": "弹簧平衡时 $mg=kd$，所以弹簧振子周期 $2\\pi\\sqrt{m/k}=2\\pi\\sqrt{d/g}$。单摆周期为 $2\\pi\\sqrt{\\ell/g}$。",
        "steps": [
          {
            "title": "比较周期",
            "content": "$$2\\pi\\sqrt{\\frac{d}{g}}=2\\pi\\sqrt{\\frac{\\ell}{g}}$$\n\n$$\\ell=d$$"
          }
        ],
        "finalAnswer": "④ $\\dfrac{\\ell}{d}=1$",
        "correctOption": "④"
      }
    },
    {
      "id": "2019-r1-phys-6",
      "number": "I-F 问6",
      "topic": "半径 2R 圆轨道卫星周期",
      "topicTag": "力学·万有引力",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "地球半径为 $R$，地表重力加速度大小为 $g$。人工卫星绕地心作半径 $2R$ 的等速圆周运动，求周期。",
      "options": [
        {
          "label": "①",
          "content": "$\\pi\\sqrt{\\dfrac{R}{g}}$"
        },
        {
          "label": "②",
          "content": "$\\pi\\sqrt{\\dfrac{2R}{g}}$"
        },
        {
          "label": "③",
          "content": "$2\\pi\\sqrt{\\dfrac{R}{g}}$"
        },
        {
          "label": "④",
          "content": "$2\\pi\\sqrt{\\dfrac{2R}{g}}$"
        },
        {
          "label": "⑤",
          "content": "$4\\pi\\sqrt{\\dfrac{R}{g}}$"
