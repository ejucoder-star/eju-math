    },
    {
      "id": "2019-r1-phys-9",
      "number": "II-C 问3",
      "topic": "p-V 图像中的吸热量",
      "topicTag": "热力学·热力学第一定律",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "一定量单原子理想气体在 $p-V$ 图中由状态 A 到状态 B。A 为 $(3V_0,p_0)$，B 为 $(V_0,3p_0)$，路径为直线。求整个过程中气体吸收的净热量。",
      "options": [
        {
          "label": "①",
          "content": "$2p_0V_0$"
