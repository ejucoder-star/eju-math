          },
          {
            "title": "(3) 比较吸热量",
            "content": "由 $Q=\\Delta U+W$，得到\n\n$$Q_I<Q_{II}<Q_{III}$$"
          }
        ],
        "finalAnswer": "① $Q_I<Q_{II}<Q_{III}$",
        "correctOption": "①"
      }
    },
    {
      "id": "2021-r1-phys-10",
      "number": "III-A 问1",
      "topic": "行波相位判断",
      "topicTag": "波动·正弦波",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "沿 $x$ 轴正方向传播、频率 $10\\,\\mathrm{Hz}$ 的正弦波如图。求 $t=0$ 以后，在 $x=10.0\\,\\mathrm{cm}$ 处位移第一次达到正最大值的时刻 $t_1$。",
      "options": [
        {
          "label": "①",
          "content": "$2.5\\times10^{-2}\\,\\mathrm{s}$"
        },
        {
          "label": "②",
          "content": "$5.0\\times10^{-2}\\,\\mathrm{s}$"
        },
        {
          "label": "③",
          "content": "$7.5\\times10^{-2}\\,\\mathrm{s}$"
        },
        {
          "label": "④",
          "content": "$1.0\\times10^{-1}\\,\\mathrm{s}$"
        }
      ],
      "questionImage": "/images/2021_R1_physics/q10.png",
      "solution": {
        "translation": "在 $x=10.0\\,\\mathrm{cm}$ 处，$t=0$ 时位移为 0。由于波向右传播，该点接下来先向负方向运动。",
        "analysis": "频率为 $10\\,\\mathrm{Hz}$，周期 $T=0.10\\,\\mathrm{s}$。从 0 且先向负方向，到第一次正最大需要 $3T/4$。",
        "steps": [
