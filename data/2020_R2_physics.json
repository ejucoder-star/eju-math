          {
            "title": "(2) 比较万有引力",
            "content": "$$\\frac{F_a}{F_{surface}}=\\frac{GMm/(10R)^2}{GMm/R^2}=\\frac1{100}$$"
          }
        ],
        "finalAnswer": "④ $\\dfrac1{100}$",
        "correctOption": "④"
      }
    },
