    {
      "id": "2020-r2-phys-1",
      "number": "I-A 问1",
      "topic": "非均匀棒的重心位置",
      "topicTag": "力学·力矩平衡",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "长度 $L$、质量 $M$ 的非均匀细棒两端受竖直向上的力而水平静止。左端的力大小为 $f$，从左端到重心 $G$ 的距离为 $x$，求 $x/L$。",
      "options": [
        {
          "label": "①",
          "content": "$\\dfrac{Mg}{f}$"
        },
        {
          "label": "②",
          "content": "$\\dfrac{f}{Mg}$"
        },
        {
          "label": "③",
          "content": "$\\dfrac{Mg}{f}-1$"
        },
        {
          "label": "④",
          "content": "$1-\\dfrac{f}{Mg}$"
        },
        {
          "label": "⑤",
          "content": "$\\dfrac{f}{Mg-f}$"
        },
        {
          "label": "⑥",
          "content": "$\\dfrac{f}{Mg+f}$"
        }
      ],
      "questionImage": "/images/2020_R2_physics/q01.png",
      "solution": {
        "translation": "棒静止时合力和力矩都为 0。先用合力求右端支持力，再对左端取力矩。",
        "analysis": "右端向上的力为 $Mg-f$。以左端为转轴，右端力的力矩与重力的力矩平衡。",
        "steps": [
          {
            "title": "(1) 合力平衡",
            "content": "$$f+F_R=Mg$$\n\n$$F_R=Mg-f$$"
          },
          {
            "title": "(2) 对左端取力矩",
            "content": "$$(Mg-f)L=Mgx$$"
          },
          {
            "title": "(3) 求比值",
            "content": "$$\\frac{x}{L}=\\frac{Mg-f}{Mg}=1-\\frac{f}{Mg}$$"
          }
        ],
        "finalAnswer": "④ $1-\\dfrac{f}{Mg}$",
        "correctOption": "④"
      }
    },
    {
      "id": "2020-r2-phys-2",
      "number": "I-B 问2",
      "topic": "减速台车中的弹簧形变",
      "topicTag": "力学·非惯性系",
      "questionType": "choice",
      "humanVerified": true,
      "answer_match": true,
      "needs_review": false,
      "japanese": "光滑台车向右运动并以 $3\\,\\mathrm{m/s^2}$ 的加速度大小减速。台车上弹簧劲度系数为 $30\\,\\mathrm{N/m}$，一端固定在右壁，另一端连接质量 $0.5\\,\\mathrm{kg}$ 的小物体。小物体相对台车静止，求弹簧形变量。",
      "options": [
        {
          "label": "①",
          "content": "0.03 m 缩んでいた"
        },
        {
          "label": "②",
          "content": "0.05 m 缩んでいた"
        },
        {
          "label": "③",
          "content": "0.1 m 缩んでいた"
        },
        {
          "label": "④",
          "content": "0.03 m 伸びていた"
        },
        {
          "label": "⑤",
          "content": "0.05 m 伸びていた"
        },
        {
          "label": "⑥",
          "content": "0.1 m 伸びていた"
        }
      ],
      "questionImage": "/images/2020_R2_physics/q02.png",
      "solution": {
        "translation": "台车向右运动但在减速，所以加速度向左。在台车参考系中，小物体受向右的惯性力。",
        "analysis": "小物体相对台车静止，弹簧力必须向左来平衡向右的惯性力。因此弹簧处于压缩状态，且 $kx=ma$。",
        "steps": [
          {
            "title": "(1) 求惯性力大小",
            "content": "$$ma=0.5\\times3=1.5\\,\\mathrm{N}$$"
          },
          {
            "title": "(2) 由弹簧力平衡",
            "content": "$$kx=ma$$\n\n$$x=\\frac{1.5}{30}=0.05\\,\\mathrm{m}$$"
          },
          {
            "title": "(3) 判断伸缩方向",
            "content": "弹簧要给小物体向左的力，所以弹簧被压缩。"
          }
        ],
        "finalAnswer": "② 0.05 m 缩んでいた",
        "correctOption": "②"
      }
    },
