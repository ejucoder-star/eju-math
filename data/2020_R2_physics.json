        },
        {
          "label": "④",
          "content": "$\\dfrac1{100}$"
        },
        {
          "label": "⑤",
          "content": "$\\dfrac1{50}$"
        },
        {
          "label": "⑥",
          "content": "$\\dfrac1{25}$"
